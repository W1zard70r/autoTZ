from typing import List, Any, Dict, Optional
from pydantic import BaseModel, Field
from .enums import TZSectionEnum, DataEnum, TemplateType

class DataSource(BaseModel):
    source_type: DataEnum
    content: Any
    file_name: str
    metadata: Optional[Dict[str, Any]] = Field(default_factory=dict)

class GeneratedSection(BaseModel):
    section_id: TZSectionEnum
    title: str
    content_markdown: str = Field(description="Текст раздела в формате Markdown")

class FullTZDocument(BaseModel):
    project_name: str
    version: str
    template_type: TemplateType = TemplateType.IT_PROJECT
    sections: List[GeneratedSection] = Field(default_factory=list)
